<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="bibliotecaCulturaPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entities -->
        <class>com.bibliotecacultura.entity.Funcionario</class>
        <class>com.bibliotecacultura.entity.Categoria</class>
        <class>com.bibliotecacultura.entity.Livro</class>
        <class>com.bibliotecacultura.entity.Exemplar</class>
        <class>com.bibliotecacultura.entity.Cliente</class>
        <class>com.bibliotecacultura.entity.Emprestimo</class>

        <properties>
            <!-- Connection — override with env vars or a config file in production -->
            <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://localhost:5432/biblioteca_cultura"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="postgres"/>

            <!-- HikariCP pool -->
            <property name="hibernate.hikari.minimumIdle"       value="2"/>
            <property name="hibernate.hikari.maximumPoolSize"   value="10"/>
            <property name="hibernate.hikari.idleTimeout"       value="30000"/>

            <!-- Schema: validate against existing DB (never auto-create in prod) -->
            <property name="hibernate.hbm2ddl.auto"    value="validate"/>
            <property name="hibernate.dialect"         value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql"        value="false"/>
            <property name="hibernate.format_sql"      value="true"/>
        </properties>
    </persistence-unit>
</persistence>
